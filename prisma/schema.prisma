// =========================================================
// INDIAN ELIXIR — Database Schema (PostgreSQL + Prisma)
// =========================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

// Singleton row (id always "main") holding the public-facing site info
// the admin can edit from /admin/settings - footer contact details,
// company description, and the WhatsApp number orders get routed to.
model SiteSettings {
  id                String   @id @default("main")
  companyName       String   @default("Indian Elixir")
  companyBlurb      String   @default("Honoring ancestral Tamil wisdom through pure, farm-rooted ingredients.")
  aboutStory        String   @default("")
  supportEmail      String   @default("hello@indianelixir.com")
  supportPhone      String   @default("+91 99999 99999")
  helpQueriesEmail  String   @default("help@indianelixir.com")
  orderWhatsApp     String   @default("919999999999")
  updatedAt         DateTime @updatedAt
}


model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  passwordHash  String
  role          Role      @default(USER)

  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  addresses     Address[]
  activities    ActivityLog[]

  @@index([email])
  @@index([role])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  line1       String
  city        String
  state       String
  pincode     String
  isDefault   Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@index([userId])
}

model Product {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String
  price         Decimal       @db.Decimal(10, 2)
  stock         Int           @default(0)
  status        ProductStatus @default(ACTIVE)
  category      String?

  images        ProductImage[]
  orderItems    OrderItem[]
  reviews       Review[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([slug])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  url         String
  publicId    String?  // cloudinary public id, for deletion/replace
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([productId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique // human readable e.g. IE-000123

  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  customerName    String
  phone           String      // WhatsApp number used for confirmation
  email           String

  addressLine1    String
  city            String
  state           String
  pincode         String
  notes           String?

  totalAmount     Decimal     @db.Decimal(10, 2)
  paymentMethod   String      @default("COD") // placeholder until gateway added
  paymentStatus   String      @default("PENDING")

  status          OrderStatus @default(PENDING)

  items           OrderItem[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  productName String   // snapshot at time of order
  unitPrice   Decimal  @db.Decimal(10, 2)
  quantity    Int

  @@index([orderId])
  @@index([productId])
}

// Tracks user-facing activity for the profile page & admin "user activity" view
model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String   // e.g. "ORDER_PLACED", "LOGIN", "PROFILE_UPDATED"
  message     String
  metadata    Json?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
}

model Review {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userName    String
  userEmail   String?
  rating      Int      @default(5)
  comment     String
  createdAt   DateTime @default(now())

  @@index([productId])
}
